{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Kennisbank",
  "colors": {
    "primary": "#152cc9",
    "light": "#4D7FFF",
    "dark": "#0A1F7F"
  },
  "favicon": "/images/beeldmerk1.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Tools",
          "icon": "book-open-cover",
          "href": "https://demasvandijk.nl/tools"
        },
        {
          "anchor": "Artikelen",
          "icon": "newspaper",
          "href": "https://demasvandijk.nl/artikelen/"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/demas-logo.svg",
    "dark": "/images/demas-dark-logo.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hello@demasvandijk.nl"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "facebook": "https://www.facebook.com/demas.vandijk/",
      "instagram": "https://www.instagram.com/demas.digital/",
      "linkedin": "https://www.linkedin.com/in/demasvandijk/",
      "youtube": "https://www.youtube.com/@demasvandijk"
    }
  },
  "description": "Hier vind je uitgebreide handleidingen",
  "fonts": {
    "family": "Inter"
  },
  "errors": {
    "404": {
      "description": "De pagina die je zoekt bestaat niet.",
      "title": "Pagina niet gevonden"
    }
  }
}
